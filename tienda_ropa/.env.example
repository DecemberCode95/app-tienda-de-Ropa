# Variables de entorno para el proyecto Tienda de Ropa
# Copia este archivo a .env y ajusta los valores

# Django Settings
DEBUG=True
SECRET_KEY=tu-clave-secreta-muy-segura-cambiala-en-produccion
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos PostgreSQL
DB_NAME=tienda_ropa_db
DB_USER=tienda_user
DB_PASSWORD=tu-password-seguro
DB_HOST=db
DB_PORT=5432

# Para SQLite en desarrollo local (descomentar si se usa SQLite)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (opcional, para notificaciones)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-password-de-app
